{
  "name": "clinic-scheduling-platform",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "offline": "serverless offline --host 0.0.0.0",
    "deploy": "serverless deploy",
    "remove": "serverless remove",
    "pretest": "tsc -p tsconfig.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "docs": "redocly build-docs ./src/docs/openapi.yaml -o ./docs/swagger.html",
    "localstack:up": "docker compose -f docker-compose.localstack.yml up -d",
    "localstack:down": "docker compose -f docker-compose.localstack.yml down -v"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1076.0",
    "aws-xray-sdk-core": "^3.6.0",
    "@aws-sdk/client-eventbridge": "^3.1076.0",
    "@aws-sdk/client-sns": "^3.1076.0",
    "@aws-sdk/client-sqs": "^3.1076.0",
    "@aws-sdk/client-ssm": "^3.1076.0",
    "@aws-sdk/lib-dynamodb": "^3.1076.0",
    "mysql2": "^3.11.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.25.9",
    "eslint": "^9.0.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "@redocly/cli": "^2.35.1",
    "serverless": "^4.0.0",
    "serverless-esbuild": "^1.57.2",
    "serverless-offline": "^14.7.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}